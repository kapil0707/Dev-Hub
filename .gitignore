# =============================================================================
# Universal Dev-Hub — Monorepo .gitignore
# =============================================================================

# --- Chat history (local notes, not part of source code) ---------------------
AG_Agent_Chat_History.md

# --- Environment & Secrets (NEVER commit these!) ----------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Python Virtual Environments
.venv/
venv/
env/
ENV/

# Pytest & Coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# --- Node.js / Next.js -------------------------------------------------------
node_modules/
.next/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend/.env*.local

# --- TypeScript --------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# --- IDE & Editor ------------------------------------------------------------
.idea/
.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker ------------------------------------------------------------------
docker-compose.override.yml

# --- Logs & Temp Files -------------------------------------------------------
*.log
logs/
tmp/
temp/

# --- OS Files ----------------------------------------------------------------
Desktop.ini
